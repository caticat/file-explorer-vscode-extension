{
  "name": "workspace-file-explorer",
  "displayName": "Simple File Explorer",
  "description": "A Windows Explorer-style file manager for VS Code with tabs, tiled panes, fast search, and Remote SSH support.",
  "version": "0.2.11",
  "publisher": "panjie039",
  "repository": {
    "type": "git",
    "url": "https://github.com/caticat/file-explorer-vscode-extension.git"
  },
  "homepage": "https://github.com/caticat/file-explorer-vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/caticat/file-explorer-vscode-extension/issues"
  },
  "license": "MIT",
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "file explorer",
    "file manager",
    "tabbed explorer",
    "folder browser",
    "remote ssh",
    "large folders",
    "workspace",
    "productivity"
  ],
  "icon": "assets/file-explorer.png",
  "files": [
    "dist/**",
    "assets/**",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:workspaceFileExplorer.open",
    "onCommand:workspaceFileExplorer.toggleViewLocation",
    "onCommand:workspaceFileExplorer.toggle",
    "onCommand:workspaceFileExplorer.newTab",
    "onCommand:workspaceFileExplorer.closeTab",
    "onCommand:workspaceFileExplorer.nextTab",
    "onCommand:workspaceFileExplorer.previousTab",
    "onCommand:workspaceFileExplorer.activateTab1",
    "onCommand:workspaceFileExplorer.activateTab2",
    "onCommand:workspaceFileExplorer.activateTab3",
    "onCommand:workspaceFileExplorer.activateTab4",
    "onCommand:workspaceFileExplorer.activateTab5",
    "onCommand:workspaceFileExplorer.activateTab6",
    "onCommand:workspaceFileExplorer.activateTab7",
    "onCommand:workspaceFileExplorer.activateTab8",
    "onCommand:workspaceFileExplorer.activateTab9",
    "onCommand:workspaceFileExplorer.focusSearch",
    "onCommand:workspaceFileExplorer.focusAddressBar",
    "onCommand:workspaceFileExplorer.toggleHiddenFiles",
    "onCommand:workspaceFileExplorer.setDetailsView",
    "onCommand:workspaceFileExplorer.setLargeIconsView",
    "onCommand:workspaceFileExplorer.toggleFolderTree",
    "onCommand:workspaceFileExplorer.collapseFolderTree",
    "onCommand:workspaceFileExplorer.toggleTiledTabs",
    "onCommand:workspaceFileExplorer.openFromExplorer",
    "onCommand:workspaceFileExplorer.revealInSimpleFileExplorer",
    "onView:workspaceFileExplorer.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "workspaceFileExplorer.open",
        "title": "Simple File Explorer: Open"
      },
      {
        "command": "workspaceFileExplorer.toggle",
        "title": "Simple File Explorer: Toggle"
      },
      {
        "command": "workspaceFileExplorer.newTab",
        "title": "Simple File Explorer: New Tab"
      },
      {
        "command": "workspaceFileExplorer.closeTab",
        "title": "Simple File Explorer: Close Tab"
      },
      {
        "command": "workspaceFileExplorer.nextTab",
        "title": "Simple File Explorer: Next Tab"
      },
      {
        "command": "workspaceFileExplorer.previousTab",
        "title": "Simple File Explorer: Previous Tab"
      },
      {
        "command": "workspaceFileExplorer.activateTab1",
        "title": "Simple File Explorer: Activate Tab 1"
      },
      {
        "command": "workspaceFileExplorer.activateTab2",
        "title": "Simple File Explorer: Activate Tab 2"
      },
      {
        "command": "workspaceFileExplorer.activateTab3",
        "title": "Simple File Explorer: Activate Tab 3"
      },
      {
        "command": "workspaceFileExplorer.activateTab4",
        "title": "Simple File Explorer: Activate Tab 4"
      },
      {
        "command": "workspaceFileExplorer.activateTab5",
        "title": "Simple File Explorer: Activate Tab 5"
      },
      {
        "command": "workspaceFileExplorer.activateTab6",
        "title": "Simple File Explorer: Activate Tab 6"
      },
      {
        "command": "workspaceFileExplorer.activateTab7",
        "title": "Simple File Explorer: Activate Tab 7"
      },
      {
        "command": "workspaceFileExplorer.activateTab8",
        "title": "Simple File Explorer: Activate Tab 8"
      },
      {
        "command": "workspaceFileExplorer.activateTab9",
        "title": "Simple File Explorer: Activate Tab 9"
      },
      {
        "command": "workspaceFileExplorer.focusSearch",
        "title": "Simple File Explorer: Focus Search"
      },
      {
        "command": "workspaceFileExplorer.focusAddressBar",
        "title": "Simple File Explorer: Focus Address Bar"
      },
      {
        "command": "workspaceFileExplorer.toggleHiddenFiles",
        "title": "Simple File Explorer: Toggle Hidden Files"
      },
      {
        "command": "workspaceFileExplorer.setDetailsView",
        "title": "Simple File Explorer: Details View"
      },
      {
        "command": "workspaceFileExplorer.setLargeIconsView",
        "title": "Simple File Explorer: Large Icons"
      },
      {
        "command": "workspaceFileExplorer.toggleFolderTree",
        "title": "Simple File Explorer: Toggle Folder Tree"
      },
      {
        "command": "workspaceFileExplorer.collapseFolderTree",
        "title": "Simple File Explorer: Collapse Folder Tree"
      },
      {
        "command": "workspaceFileExplorer.toggleTiledTabs",
        "title": "Simple File Explorer: Toggle Tiled Tabs"
      },
      {
        "command": "workspaceFileExplorer.toggleViewLocation",
        "title": "Simple File Explorer: Move Between Editor and Sidebar"
      },
      {
        "command": "workspaceFileExplorer.openFromExplorer",
        "title": "Show in Simple File Explorer",
        "icon": "$(folder-opened)"
      },
      {
        "command": "workspaceFileExplorer.revealInSimpleFileExplorer",
        "title": "Show in Simple File Explorer",
        "icon": "$(folder-opened)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "simpleFileExplorer",
          "title": "Simple File Explorer",
          "icon": "$(folder-opened)"
        }
      ]
    },
    "views": {
      "simpleFileExplorer": [
        {
          "id": "workspaceFileExplorer.sidebar",
          "name": "Simple File Explorer",
          "type": "webview",
          "when": "config.simpleFileExplorer.viewLocation == sidebar"
        }
      ]
    },
    "keybindings": [
      {
        "command": "workspaceFileExplorer.toggle",
        "key": "ctrl+alt+q",
        "mac": "cmd+alt+q"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "workspaceFileExplorer.open"
        },
        {
          "command": "workspaceFileExplorer.toggleViewLocation"
        },
        {
          "command": "workspaceFileExplorer.openFromExplorer",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "workspaceFileExplorer.openFromExplorer",
          "when": "resourceScheme == file",
          "group": "navigation@9"
        }
      ],
      "editor/title/context": [
        {
          "command": "workspaceFileExplorer.revealInSimpleFileExplorer",
          "when": "resourceScheme == file",
          "group": "9_cutcopypaste@60"
        }
      ]
    },
    "configuration": {
      "title": "Simple File Explorer",
      "properties": {
        "simpleFileExplorer.restoreWorkspaceSession": {
          "type": "boolean",
          "default": true,
          "description": "Restore tab order, current paths, and the active tab separately for each VS Code workspace."
        },
        "simpleFileExplorer.viewLocation": {
          "type": "string",
          "enum": [
            "editor",
            "sidebar"
          ],
          "default": "editor",
          "description": "Choose where Simple File Explorer opens. Use editor for the full editor-tab view, or sidebar for the Activity Bar view."
        },
        "simpleFileExplorer.iconThemeMode": {
          "type": "string",
          "enum": [
            "auto",
            "codicon"
          ],
          "default": "auto",
          "description": "Choose file and folder icons. Use auto to reuse the current VS Code file icon theme when possible, or codicon to always use the built-in fallback icons."
        },
        "simpleFileExplorer.treeProbeChildFolders": {
          "type": "boolean",
          "default": false,
          "description": "Check whether folders in the editor tree have visible child folders before showing expand arrows. Disabled by default for better performance."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "check": "tsc --noEmit",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test test/webviewUtils.test.mjs",
    "compile": "npm run check && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run check && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.0"
  }
}
